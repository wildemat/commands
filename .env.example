# ============================================================
# Go Process Orchestrator Configuration
# ============================================================
# Copy this file to .env and customize as needed.
# Environment variables take precedence over .env values.

# ============================================================
# Directory Paths
# ============================================================
# Path to your Kibana repository
KIBANA_DIR=~/workplace/kibana

# Directory where process logs will be stored
LOG_DIR=~/workplace/local_dev_logs

# Path to NVM installation
NVM_DIR=~/.nvm

# Directory containing process scripts
SCRIPTS_DIR=./scripts

# ============================================================
# Browser Configuration
# ============================================================
# Path to browser executable for opening Kibana
# macOS Chrome (default):
BROWSER_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# macOS Firefox:
# BROWSER_PATH=/Applications/Firefox.app/Contents/MacOS/firefox
# Linux Chrome:
# BROWSER_PATH=/usr/bin/google-chrome

# ============================================================
# Log Viewing Configuration
# ============================================================
# Command to open log files
# Options: "open" (macOS default), "code" (VS Code), "vim", "nano", "tail -f"
LOG_OPEN_CMD=open

# ============================================================
# Process Ports
# ============================================================
PORT_ESSLS=9200
PORT_ESSTACK=9201
PORT_KBNSLS=5601
PORT_KBNSTACK=5611

# ============================================================
# Process-Specific Memory Limits (optional)
# ============================================================
# OPTIMIZER_MEMORY_LIMIT=4G
# ESSLS_MEMORY_LIMIT=8G
# KBNSLS_MEMORY_LIMIT=4G
# KBNSTACK_MEMORY_LIMIT=4G

# ============================================================
# Extra Arguments (optional)
# ============================================================
# ESSLS_EXTRA_ARGS=-E xpack.security.enabled=false
# KBNSLS_EXTRA_ARGS=--no-base-path
