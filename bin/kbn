#!/bin/bash
# Kibana Process Orchestrator
# This script launches the Go-based process orchestrator

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ORCHESTRATOR="$SCRIPT_DIR/kbn-orchestrator"

# Check if orchestrator binary exists
if [ ! -f "$ORCHESTRATOR" ]; then
    echo "Error: Orchestrator binary not found at $ORCHESTRATOR"
    echo "Please run: go build -o bin/kbn-orchestrator ./cmd/kbn/"
    exit 1
fi

# Run the orchestrator
exec "$ORCHESTRATOR" "$@"
